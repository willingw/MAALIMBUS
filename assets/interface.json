{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaLIMBUS",
    "description": "这是一个使用 MaaFramework 创建的新项目。用于我本人的边狱巴士自动化",
    "contact": "暂无",
    "license": "MIT",
    "welcome": "欢迎使用 MaaLIMBUS!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/willingw/MAALIMBUS",
    "version": "1.0.0",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^LimbusCompany$",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "默认",
            "path": [
                "./resource"
            ]
        }
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
    "task": [
        {
            "name": "启动到主界面",
            "entry": "bootstrap_start"
        },
        {
            "name": "领取邮件",
            "entry": "mail_claim"
        }
    ],
    "option": {}
}
